    "ingredients": [
      "250 g dry chickpeas, soaked overnight",
      "1 medium onion",
      "4–5 cloves garlic",
      "1 cup parsley",
      "1 cup cilantro",
      "½ cup dill (optional)",
      "1 tsp baking soda",
      "2 tsp cumin",
      "2 tsp coriander",
      "1 tsp black pepper",
      "½ tsp Aleppo pepper",
      "1½ tsp salt",
      "2 tbsp sesame seeds",
      "Oil for frying"
