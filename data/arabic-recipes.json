[
  {
    "id": 201,
    "title": "Falafel",
    "category": "Middle Eastern",
    "time": "45 min (plus soaking)",
    "difficulty": "Medium",
    "image": "falafel.jpg",

    "ingredients": [
      {
        "group": "Base",
        "items": [
          "250 g dried chickpeas (soaked overnight)",
          "1 medium onion, chopped",
          "4–5 garlic cloves",
          "1 tsp baking soda",
          "Salt to taste"
        ]
      },
      {
        "group": "Fresh Herbs",
        "items": [
          "1 cup parsley",
          "1 cup cilantro",
          "1/2 cup dill (optional)"
        ]
      },
      {
        "group": "Spices",
        "items": [
          "2 tsp cumin",
          "2 tsp coriander",
          "1 tsp black pepper",
          "1/2 tsp chili flakes (optional)"
        ]
      },
      {
        "group": "Binding & Frying",
        "items": [
          "1–2 tbsp chickpea flour (if needed)",
          "2 tbsp sesame seeds",
          "Oil for deep frying"
        ]
      }
    ],

    "instructions": [
      {
        "group": "Prepare Chickpeas",
        "steps": [
          "Soak chickpeas overnight (do not cook)",
          "Drain completely"
        ]
      },
      {
        "group": "Make Mixture",
        "steps": [
          "Blend chickpeas, onion, garlic, and herbs",
          "Pulse until grainy texture",
          "Add spices and chill mixture"
        ]
      },
      {
        "group": "Shape & Fry",
        "steps": [
          "Add baking soda before frying",
          "Form balls or patties",
          "Deep fry at 170–180°C until golden"
        ]
      }
    ],

    "tips": [
      "Never use canned chickpeas",
      "Keep mixture chilled before frying",
      "Maintain correct oil temperature for crisp texture"
    ]
  },

  {
    "id": 202,
    "title": "Hummus",
    "category": "Middle Eastern",
    "time": "1.5 hours",
    "difficulty": "Medium",
    "image": "hummus.jpg",

    "ingredients": [
      {
        "group": "Base",
        "items": [
          "250 g dried chickpeas",
          "1 tsp baking soda"
        ]
      },
      {
        "group": "Tahini Mix",
        "items": [
          "120 g tahini",
          "80 ml lemon juice",
          "1 garlic clove",
          "80–100 ml ice water",
          "Salt to taste"
        ]
      },
      {
        "group": "Garnish",
        "items": [
          "Olive oil",
          "Paprika or sumac",
          "Parsley",
          "Optional pine nuts"
        ]
      }
    ],

    "instructions": [
      {
        "group": "Cook Chickpeas",
        "steps": [
          "Soak chickpeas overnight",
          "Cook until very soft (1–1.5 hours)"
        ]
      },
      {
        "group": "Prepare Base",
        "steps": [
          "Mix lemon juice and garlic",
          "Let rest for flavor balance"
        ]
      },
      {
        "group": "Blend Hummus",
        "steps": [
          "Blend chickpeas with tahini",
          "Add ice water slowly",
          "Blend until smooth and creamy"
        ]
      },
      {
        "group": "Serve",
        "steps": [
          "Spread in bowl",
          "Drizzle olive oil",
          "Add garnish"
        ]
      }
    ],

    "tips": [
      "Use dried chickpeas only",
      "Ice water makes it extra creamy",
      "Serve at room temperature"
    ]
  }
]
