    "steps": [
      "Soak chickpeas overnight.",
      "Drain thoroughly.",
      "Blend chickpeas with herbs and onion.",
      "Add spices and mix well.",
      "Chill mixture.",
      "Form balls.",
      "Fry at 170–180°C until golden.",
      "Drain and serve hot."
    ],

    "servingSuggestions": [
      "Serve in pita bread with vegetables.",
      "Add tahini sauce and pickles."
    ],

