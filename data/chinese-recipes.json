{
  "id": 101,
  "title": "Fish Szechuan Sauce",
  "image": "Fish Szechuan Sauce.png",
  "time": "30 min",
  "difficulty": "Medium",
  "category": "Chinese",

  "ingredients": [
    {
      "group": "For the Fish",
      "items": [
        "500g white fish fillets",
        "1 tsp salt"
      ]
    },
    {
      "group": "For the Szechuan Sauce",
      "items": [
        "2 tbsp vegetable oil",
        "3 garlic cloves, minced"
      ]
    },
    {
      "group": "Garnish",
      "items": [
        "Fresh cilantro",
        "Toasted sesame seeds"
      ]
    }
  ],

  "instructions": [
    {
      "group": "Prepare the Fish",
      "steps": [
        "Pat fish dry and season",
        "Coat with cornstarch",
        "Pan fry until golden"
      ]
    },
    {
      "group": "Make Sauce",
      "steps": [
        "Heat oil and aromatics",
        "Add soy sauce and vinegar",
        "Simmer until thick"
      ]
    },
    {
      "group": "Combine & Serve",
      "steps": [
        "Pour sauce over fish",
        "Garnish and serve hot"
      ]
    }
  ],

  "tips": [
    "Keep pan hot for crispy fish",
    "Balance salt and soy sauce carefully"
  ]
}
