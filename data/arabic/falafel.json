{
  "id": 101,
  "title": "Falafel",
  "category": "Arabic",
  "time": "45 min",
  "difficulty": "Medium",
  "image": "assets/images/arabic/falafel.png",

  "ingredients": [
    {
      "title": "Main Ingredients",
      "items": [
        "250 g dry chickpeas (soaked overnight)",
        "1 medium onion",
        "4–5 cloves garlic",
        "1 cup parsley",
        "1 cup cilantro"
      ]
    },
    {
      "title": "Spices",
      "items": [
        "2 tsp cumin",
        "2 tsp coriander",
        "1 tsp black pepper",
        "1½ tsp salt",
        "½ tsp chili flakes"
      ]
    },
    {
      "title": "Binding & Frying",
      "items": [
        "1 tsp baking soda",
        "2 tbsp sesame seeds",
        "Oil for deep frying"
      ]
    }
  ],

  "steps": [
    "Soak chickpeas overnight in cold water.",
    "Drain chickpeas completely.",
    "Blend chickpeas with onion, garlic, and herbs.",
    "Add spices and mix well until coarse texture.",
    "Chill mixture for 30 minutes.",
    "Form balls or patties.",
    "Fry at 170–180°C until golden brown.",
    "Serve hot with pita and tahini sauce."
  ],

  "chefTips": [
    "Never use canned chickpeas.",
    "Keep mixture chilled before frying.",
    "Oil temperature is critical for crisp texture."
  ]
}
