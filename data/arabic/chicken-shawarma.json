{
  "id": 103,
  "title": "Chicken Shawarma",
  "category": "Arabic",
  "time": "45 min",
  "difficulty": "Medium",
  "image": "assets/images/arabic/chicken-shawarma.png",

  "ingredients": [
    "1 kg boneless chicken thighs",
    "4 cloves garlic, minced",
    "1 tbsp ground cumin",
    "1 tbsp ground coriander",
    "1 tsp ground paprika",
    "1 tsp ground turmeric",
    "1/2 tsp ground cinnamon",
    "1/2 tsp ground allspice",
    "1/4 tsp ground cardamom (optional)",
    "1 tsp chili powder (optional)",
    "1 tsp salt",
    "1/2 tsp black pepper",
    "4 tbsp plain yogurt",
    "3 tbsp olive oil",
    "Juice of 1 lemon",
    "1 small onion, grated (optional)",
    "2 tbsp vinegar (optional)",
    "Pita bread for serving",
    "Garlic sauce or tahini sauce",
    "Pickles, parsley, vegetables for serving"
  ],

  "steps": [
    "Slice chicken into thin strips.",
    "Mix garlic, spices, yogurt, oil, lemon juice, onion, and vinegar.",
    "Add chicken and marinate for at least 4 hours or overnight.",
    "Preheat oven to 200°C (400°F).",
    "Bake chicken for 20–25 minutes until cooked and slightly charred.",
    "Or cook in skillet 4–5 minutes per side until golden.",
    "Slice and serve in pita with garlic sauce and vegetables.",
    "Optional: broil for extra charred flavor."
  ],

  "chefTips": [
    "Use chicken thighs for juiciness.",
    "Marinate overnight for best flavor.",
    "High heat gives authentic shawarma char.",
    "Garlic sauce enhances taste significantly."
  ]
}
